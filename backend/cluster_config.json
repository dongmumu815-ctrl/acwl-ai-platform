{
  "database": {
    "host": "localhost",
    "port": 3306,
    "user": "root",
    "password": "password",
    "database": "acwl_ai_data"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": null,
    "db": 0
  },
  "scheduler": {
    "default_instances": 3,
    "max_instances": 5,
    "heartbeat_interval": 30,
    "leader_election_timeout": 60,
    "base_port": 8001,
    "health_check_interval": 10,
    "log_level": "INFO"
  },
  "executor": {
    "default_instances": 3,
    "max_instances": 10,
    "heartbeat_interval": 30,
    "task_poll_interval": 5,
    "base_port": 8101,
    "health_check_interval": 10,
    "log_level": "INFO",
    "groups": {
      "default": {
        "max_concurrent_tasks": 5,
        "task_timeout": 300,
        "retry_count": 3
      },
      "data_processing": {
        "max_concurrent_tasks": 3,
        "task_timeout": 600,
        "retry_count": 2
      },
      "ml_training": {
        "max_concurrent_tasks": 1,
        "task_timeout": 3600,
        "retry_count": 1
      }
    }
  },
  "monitoring": {
    "enabled": true,
    "metrics_port": 9090,
    "log_retention_days": 7,
    "alert_webhook": null
  },
  "security": {
    "api_key_required": false,
    "allowed_hosts": [
      "localhost",
      "127.0.0.1"
    ],
    "ssl_enabled": false
  },
  "deployment": {
    "environment": "development",
    "cluster_name": "acwl-ai-cluster",
    "node_prefix": "node",
    "auto_restart": true,
    "graceful_shutdown_timeout": 30
  }
