# ACWL AI Platform - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置
# cp .env.example .env

# ==================== 应用配置 ====================
PROJECT_NAME=ACWL-AI
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8082

# ==================== 安全配置 ====================
# 生产环境必须修改为强随机密钥
# 可使用以下命令生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AGENT_SKILL_API_KEY=your-agent-skill-api-key-here
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== CORS 配置 ====================
ALLOWED_HOSTS=["*"]

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-database-password-here
DB_NAME=acwl-ai-data
DB_CHARSET=utf8mb4

# ==================== Doris 配置 ====================
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=your-doris-password-here
DORIS_DATABASE=analytics-logs

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# ==================== Celery 配置 ====================
CELERY_BROKER_URL=redis://:your-redis-password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your-redis-password@localhost:6379/2

# ==================== MinIO 对象存储配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_SECURE=false
MINIO_BUCKET_NAME=ai-platform-data
MINIO_REGION=us-east-1

# ==================== 文件存储配置 ====================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=[".txt", ".pdf", ".docx", ".json", ".csv", ".jsonl"]

# ==================== 模型和数据集存储 ====================
MODEL_STORAGE_DIR=models
DATASET_STORAGE_DIR=datasets

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/acwl-ai.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# ==================== API 配置 ====================
API_V1_PREFIX=/api/v1

# ==================== 分页配置 ====================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==================== 缓存配置 ====================
CACHE_TTL=3600

# ==================== GPU 监控配置 ====================
ENABLE_GPU_MONITORING=true
GPU_MEMORY_THRESHOLD=0.9

# ==================== 部署配置 ====================
DEFAULT_DEPLOYMENT_TIMEOUT=300
MAX_CONCURRENT_DEPLOYMENTS=5
