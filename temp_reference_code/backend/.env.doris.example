# Doris数据库配置示例
# 复制此文件为 .env 并根据实际环境修改配置

# ===========================================
# Doris配置
# ===========================================

# 是否启用Doris存储访问日志
DORIS_ENABLED=true

# Doris集群配置
DORIS_HOST=10.20.1.201
DORIS_HTTP_PORT=8030
DORIS_QUERY_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=2wsx1QAZaczt

# 数据库和表配置
DORIS_DATABASE=cepiec-logs
DORIS_ACCESS_LOG_TABLE=api_access_logs

# 批量插入配置
DORIS_BATCH_SIZE=100
DORIS_FLUSH_INTERVAL=30

# ===========================================
# 其他配置（保持原有配置）
# ===========================================

# 应用配置
APP_NAME=自定义接口管理系统
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1
CUSTOM_API_PREFIX=/api/custom

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=1

# 数据库配置
DB_HOST=10.20.1.200
DB_PORT=3306
DB_USER=root
DB_PASSWORD=2wsx1QAZaczt
DB_NAME=acwl_api_system
DB_CHARSET=utf8mb4

# Redis配置
REDIS_HOST=10.20.1.200
REDIS_PORT=6379
REDIS_PASSWORD=1qaz2WSXaczt
REDIS_DB=0

# JWT配置
SECRET_KEY=your-super-secret-key-change-in-production-32chars-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# 文件上传配置
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,txt,csv,json

# 日志配置
LOG_LEVEL=DEBUG
LOG_FILE=./logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# 邮件配置（可选）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TLS=true
# FROM_EMAIL=your-email@gmail.com

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=9090

# 系统默认配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
DEFAULT_RATE_LIMIT=100
MAX_API_PER_CUSTOMER=10
SESSION_TIMEOUT=7200