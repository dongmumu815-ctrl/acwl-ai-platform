# MinIO对象存储配置示例
# 复制此文件为 .env 并根据实际环境修改配置

# MinIO服务配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=cepiec-read-data
MINIO_REGION=us-east-1

# 其他相关配置
# 如果MinIO服务运行在不同的主机上，请修改MINIO_ENDPOINT
# 例如：MINIO_ENDPOINT=10.20.1.200:9000

# 生产环境建议配置
# MINIO_SECURE=true  # 启用HTTPS
# MINIO_ACCESS_KEY=your-production-access-key
# MINIO_SECRET_KEY=your-production-secret-key