# DataAInsight 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 应用访问密钥（用户登录时需要输入的密钥）
# 建议使用复杂的密钥，包含字母、数字和特殊字符
DATAINSIGHT_SECRET_KEY=DataInsight@2024#Secure!Key

# JWT Token 签名密钥（用于生成和验证JWT token）
# 这个密钥应该保密，不要泄露给用户
DATAINSIGHT_JWT_SECRET=DataInsight-JWT-Secret-Key-2024!@#$%^&*()

# Token 过期时间（小时）
# 默认24小时，可以根据安全需求调整
DATAINSIGHT_TOKEN_EXPIRE_HOURS=24

# 数据库配置（如果需要）
# DATABASE_URL=sqlite:///./data_insight.db

# 服务器配置
# HOST=0.0.0.0
# PORT=8001